pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
-- smooth(er)step function demo
-- @dredds

-- wikipedia.org/wiki/smoothstep


function smoothstep(x,x0,x1)
 x0 = x0 or 0
 x1 = x1 or 1
 x = mid(0,1,(x-x0)/(x1-x0))
 
 return x^2 * (3-2*x)
end

function smootherstep(x,x0,x1)
 x0 = x0 or 0
 x1 = x1 or 1
 x = mid(0,1,(x-x0)/(x1-x0))
 
 return x^3 * (x*(6*x-15) + 10)
end



function _draw()
 cls(1)
 
 color(9)
 print("smoothstep",1,1)
 line()
 line(0,127)
 for x = 1,127 do
  local s = smoothstep(x,0,127)
  
  line(x,127-s*127)
 end
 
 local sx = 
   smoothstep(time()/2%1)
 circfill(sx*127,60,2)
 
 
 color(10)
 print("smootherstep",1,8)
 line()
 line(0,127)
 for x = 0,127 do
  local ss = smootherstep(x,0,127)
  line(x,127-ss*127)
 end
 
 local ssx = 
   smootherstep(time()/2%1)
 circfill(ssx*127,68,2)
end
